# Nunca publiques el Access Token real en GitHub.
MP_ACCESS_TOKEN=coloca_aqui_tu_nuevo_access_token
PUBLIC_BASE_URL=https://vignahome.com
ALLOWED_ORIGINS=https://vignahome.com,http://localhost:5500,http://127.0.0.1:5500
PORT=3000

# URL pública del webhook del servidor (se configura al desplegarlo).
MP_NOTIFICATION_URL=https://api-ejemplo.vignahome.com/webhook-mercadopago
MP_WEBHOOK_SECRET=coloca_aqui_la_clave_secreta_del_webhook

# Cuenta de servicio de Firebase codificada en Base64. Nunca publiques el JSON original.
FIREBASE_SERVICE_ACCOUNT_BASE64=coloca_aqui_la_cuenta_de_servicio_en_base64

# Actívalo únicamente después de sincronizar y completar las existencias en admin.html.
CONTROL_INVENTARIO=false
